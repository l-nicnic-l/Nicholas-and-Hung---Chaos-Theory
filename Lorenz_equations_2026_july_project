      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#Constants for this lorenz system. Constants are from the Lorenz atmospheric convection model\n",
        "SIGMA = 10.0\n",
        "RHO = 28.0\n",
        "BETA = 8.0 / 3.0"
      ],
      "metadata": {
        "id": "Mypf4AboOpqz"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#Defining the lorenz equations\n",
        "def lorenz_deriv(t, state, sigma=10.0, beta=8/3, rho=28.0):\n",
        "  x, y, z = state\n",
        "\n",
        "  dx = sigma * (y - x)\n",
        "  dy = x * (rho - z) - y\n",
        "  dz = x * y - beta * z\n",
        "\n",
        "  return np.array([dx, dy, dz])"
      ],
      "metadata": {
        "id": "DaJ9SDzxky8m"
      },
      "execution_count": 6,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(lorenz_deriv(0, np.array([1.0, 1.0, 1.0])))"
      ],
