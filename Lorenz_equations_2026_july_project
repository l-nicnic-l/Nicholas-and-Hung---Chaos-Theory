        "states[0] = initial_state\n",
        "t = 0.0\n",
        "for i in range(1, num_steps):\n",
        "    states[i] = rk4step(lorenz_deriv, t, states[i-1], dt)\n",
        "    t = t + dt\n",
        "\n",
        "print(states[num_steps - 1])"
