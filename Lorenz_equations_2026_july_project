    {
      "cell_type": "code",
      "source": [
        "#Defining Euler approximation algorithm\n",
        "#Euler approximation of differential equation: y(n+1) = y(n) + h * f(t(n), y(n))\n",
        "\n",
        "def eulerstep(f, t, state, h):\n",
        "  return state + h * f(t , state)"
      ],
      "metadata": {
        "id": "sPa4j_6izXcx"
      },
      "execution_count": 8,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#Variables:\n",
        "#state -> initial conditions, [x,y,z]\n",
        "#h -> step size\n",
        "#t -> current time\n",
        "#f -> functions(lorenz_deriv)"
      ],
      "metadata": {
        "id": "949zh3n1Ch3h"
      },
      "execution_count": 9,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "dt = 0.001 #stepsize\n",
        "t_max = 20.0\n",
        "num_steps = int(t_max / dt)"
      ],
      "metadata": {
        "id": "miKmSama22sg"
      },
      "execution_count": 10,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "initial_state = np.array([1.0, 1.0, 1.0])\n",
        "#np.zeroes creates array of zeroes with number of rows = num_steps and row length = len(initial_state)\n",
        "states = np.zeros((num_steps, len(initial_state)))\n",
        "#setting the first row = inital state\n",
        "states[0] = initial_state\n",
        "t = 0.0\n",
        "#loop to run euler approximation for n = num_steps times\n",
        "for i in range(1, num_steps):\n",
        "    states[i] = eulerstep(lorenz_deriv, t, states[i-1], dt)\n",
        "    t = t + dt\n",
        "\n",
        "print(states[num_steps - 1])"
      ],
