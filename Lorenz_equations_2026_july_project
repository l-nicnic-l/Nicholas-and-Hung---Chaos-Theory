      "source": [
        "#Defining euler approximation algorithm\n",
        "#Euler approximation of differential equation: y(n+1) = y(n) + h * f(t(n), y(n))"
      ],
      "metadata": {
        "id": "2pTh1WJQSjtX"
      },
      "execution_count": 16,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def euler_step(f, t, state, h):\n",
        "  return state + h * f(t , state)"
      ],
      "metadata": {
        "id": "sPa4j_6izXcx"
      },
      "execution_count": 17,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#Variables:\n",
        "#state -> initial conditions, [x,y,z]\n",
        "#h -> step size\n",
        "#t -> current time\n",
        "#f -> functions(lorenz_deriv)"
      ],
      "metadata": {
        "id": "949zh3n1Ch3h"
      },
      "execution_count": 18,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "dt = 0.01 #stepsize\n",
        "t_max = 20.0\n",
        "num_steps = int(t_max / dt)"
      ],
      "metadata": {
        "id": "miKmSama22sg"
      },
      "execution_count": 19,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "initial_state = np.array([1.0, 1.0, 1.0])\n",
        "states = np.zeros((num_steps, len(initial_state)))\n",
        "states[0] = initial_state\n",
        "t = 0.0\n",
        "for i in range(1, num_steps):\n",
        "    states[i] = euler_step(lorenz_deriv, t, states[i-1], dt)\n",
        "    t = t + dt\n",
        "\n",
        "print(states[num_steps - 1])"
      ],
