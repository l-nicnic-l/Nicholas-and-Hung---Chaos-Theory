        "#RK4 method of approximation\n",
        "# Runge-Kutta 4th Order (RK4) method equations:\n",
        "  # k1 = f(t, state)\n",
        "  # k2 = f(t + dt/2, state + (dt/2) * k1)\n",
        "  # k3 = f(t + dt/2, state + (dt/2) * k2)\n",
        "  # k4 = f(t + dt, state + dt * k3)\n",
        "\n",
        "  # state_new = state + (dt / 6) * (k1 + 2*k2 + 2*k3 + k4)"
      ],
      "metadata": {
        "id": "yHqPFs2iu76X"
      },
      "execution_count": 14,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#Defining rk4 approximation algorithm\n",
        "def rk4step(f,  t, state, dt):\n",
        "  k1 = f(t, state)\n",
        "  k2 = f(t + dt/2, state + (dt/2) * k1)\n",
        "  k3 = f(t + dt/2, state + (dt/2) * k2)\n",
        "  k4 = f(t + dt, state + dt * k3)\n",
        "  return state + (dt / 6) * (k1 + 2*k2 + 2*k3 + k4)\n"
      ],
      "metadata": {
        "id": "ggPDVrIg2-3O"
      },
      "execution_count": 15,
      "outputs": []
    },
    {
